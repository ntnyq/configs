{
  "name": "@ntnyq/configs",
  "type": "module",
  "version": "3.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepare": "husky",
    "release": "run-s release:check release:version",
    "release:check": "run-s format:check test",
    "release:version": "bumpp -r",
    "test": "pnpm -r run test"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "bumpp": "^11.0.1",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.46.0",
    "typescript": "^6.0.3"
  },
  "nano-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  }
}
