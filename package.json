{
  "name": "@ntnyq/configs",
  "type": "module",
  "version": "3.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepare": "husky",
    "release": "run-s release:check release:version",
    "release:check": "run-s format:check lint test",
    "release:version": "bumpp -r",
    "test": "pnpm -r run test"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "bumpp": "^11.0.1",
    "husky": "^9.1.7",
    "nano-staged": "^0.9.0",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^5.9.3"
  },
  "nano-staged": {
    "*.{js,ts,tsx,mjs}": "oxlint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  }
}
